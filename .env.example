# --------------------------------------------------------------------------------
#  WageShield — root .env.example
#
#  Copy to `.env.local` (gitignored) and fill in. All workspaces (contracts, issuer,
#  sdk, web) load from this single root file.
# --------------------------------------------------------------------------------

# ---- Deploy / EOA -------------------------------------------------------------

# Private key of the worker / deployer EOA. Must be funded on the target testnet.
PRIVATE_KEY=0x

# RPC URLs. The CoFHE Hardhat plugin auto-injects defaults for eth-sepolia and
# arb-sepolia, so these are only required for base-sepolia or custom RPCs.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Block-explorer API keys (only needed for `hardhat verify`).
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=

# Gas reporting (true|false)
REPORT_GAS=false

# ---- Mock timeclock issuer ---------------------------------------------------

# 0x-prefixed 32-byte hex private key. Whatever address derives from this key must
# be registered on the deployed TimeclockIssuerRegistry (run scripts/register-issuer.ts).
ISSUER_PRIVATE_KEY=0x

# Issuer service config
ISSUER_PORT=4001
ISSUER_LABEL="Mock Homebase"

# Optional: override which deployment record the issuer reads. Defaults to arb-sepolia.
NETWORK=arb-sepolia

# Optional: explicit addresses (auto-discovered from deployment record otherwise)
# WAGECLAIM_ADDRESS=
# CHAIN_ID=421614

# Optional CORS allow-list (comma-separated origins or `*`)
ALLOWED_ORIGIN=*

# ---- Web app -----------------------------------------------------------------

NEXT_PUBLIC_WAGECLAIM_ADDRESS=
NEXT_PUBLIC_RESOLVER_ADDRESS=
NEXT_PUBLIC_POLICY_ADDRESS=
NEXT_PUBLIC_ISSUER_URL=http://localhost:4001
NEXT_PUBLIC_CHAIN_ID=421614
