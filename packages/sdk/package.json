{
  "name": "@wageshield/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "WageShield client SDK — attestation typed-data builder, claim submission, CoFHE permit-gated decryption helpers. Wraps @cofhe/sdk + ethers v6.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./src/node.ts",
      "require": "./dist/node.js",
      "default": "./src/node.ts"
    },
    "./src/*": "./src/*.ts",
    "./dist/*": "./dist/*.js"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.5.1",
    "ethers": "^6.4.0"
  },
  "devDependencies": {
    "@types/node": ">=18",
    "rimraf": "^5.0.0",
    "typescript": ">=4.5.0"
  }
}
