  "description": "Mock timeclock issuer service. Signs EIP-712 TimeclockAttestation structs the way a real Homebase / 7shifts / worker-center co-op signer would.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "serve": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@wageshield/sdk": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.4.0",
    "express": "^5.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": ">=18",
    "tsx": "^4.16.0",
    "typescript": ">=4.5.0"
  }
}
